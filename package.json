{
  "name": "instant-board",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "check:skills": "npx @tanstack/intent@latest list",
    "dev": "vp dev",
    "doctor": "react-doctor . --verbose --yes --no-lint",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:dead-code": "fallow dead-code",
    "fallow:fix": "fallow fix",
    "fallow:health": "fallow health",
    "fix": "vp check --fix",
    "instant:push-perms": "INSTANT_PERMS_FILE_PATH=src/db/instant.perms.ts npx instant-cli push perms --yes",
    "instant:push-schema": "INSTANT_SCHEMA_FILE_PATH=src/db/instant-schema.ts npx instant-cli push schema --yes",
    "preview": "vp preview",
    "test": "vp test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@lightsound/cn": "^2.0.2",
    "better-result": "^2.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-typescript-lib": "^2.12.0",
    "fallow": "^2.48.4",
    "react-doctor": "^0.0.39",
    "react-grab": "^0.1.32",
    "tailwind-preset-mantine": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}